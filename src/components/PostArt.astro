---
// Cover art for blog posts: small abstract scenes in the site's route
// vocabulary (streets, route lines, stops, checks, texts). Drawn at the
// card's natural width so nothing scales up. Pass `variant` to pick one
// explicitly (lists rotate by index); otherwise the seed decides.
interface Props {
  seed: string;
  variant?: 'route' | 'check' | 'chat';
  class?: string;
}

const { seed, variant: forced, class: className } = Astro.props;

const variants = ['route', 'check', 'chat'] as const;
let hash = 0;
for (const ch of seed) hash = (hash * 31 + ch.charCodeAt(0)) >>> 0;
const variant = forced ?? variants[hash % variants.length];
---

<div class={`post-art ${className ?? ''}`} aria-hidden="true">
  {
    variant === 'route' && (
      <svg viewBox="0 0 800 96" preserveAspectRatio="xMidYMid slice">
        <g stroke="#e2e9ee" stroke-width="8">
          <path d="M0 28h800M0 68h800" />
          <path d="M130 0v96M300 0v96M470 0v96M640 0v96" />
        </g>
        <path
          d="M60 68 L130 68 L130 28 L300 28 L300 68 L470 68 L470 28 L640 28 L640 68 L740 68"
          fill="none"
          stroke="#5e845e"
          stroke-width="3"
          stroke-linecap="round"
          stroke-dasharray="1 8"
        />
        <circle cx="60" cy="68" r="7" fill="#142937" />
        <circle cx="300" cy="48" r="7" fill="#142937" />
        <circle cx="470" cy="48" r="7" fill="#142937" />
        <circle cx="740" cy="68" r="7" fill="#5e845e" />
      </svg>
    )
  }
  {
    variant === 'check' && (
      <svg viewBox="0 0 800 96" preserveAspectRatio="xMidYMid slice">
        <path d="M0 48h800" stroke="#e2e9ee" stroke-width="8" />
        {[70, 215, 360, 505, 650].map((x, i) => (
          <g>
            <rect x={x} y="27" width="110" height="42" rx="8" fill="#ffffff" stroke="#d9e2e8" stroke-width="1.5" />
            {i < 3 ? (
              <path d={`M${x + 44} 48 l8 8 14 -16`} fill="none" stroke="#5e845e" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" />
            ) : i === 3 ? (
              <circle cx={x + 55} cy="48" r="8" fill="none" stroke="#b07d2e" stroke-width="3" />
            ) : (
              <circle cx={x + 55} cy="48" r="8" fill="none" stroke="#d9e2e8" stroke-width="3" />
            )}
          </g>
        ))}
      </svg>
    )
  }
  {
    variant === 'chat' && (
      <svg viewBox="0 0 800 96" preserveAspectRatio="xMidYMid slice">
        <path d="M0 80h800" stroke="#e2e9ee" stroke-width="8" />
        <rect x="70" y="16" width="180" height="24" rx="12" fill="#eaf0f4" />
        <rect x="120" y="50" width="230" height="24" rx="12" fill="#142937" />
        <rect x="430" y="16" width="150" height="24" rx="12" fill="#eaf0f4" />
        <rect x="470" y="50" width="190" height="24" rx="12" fill="#142937" />
        <circle cx="716" cy="34" r="11" fill="#5e845e" />
        <path d="M711 34 l4 4 6 -8" fill="none" stroke="#ffffff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )
  }
</div>

<style>
  .post-art {
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: #f8fafb;
    border: 1px solid var(--line-soft);
  }

  .post-art svg {
    display: block;
    width: 100%;
    height: 88px;
  }
</style>
