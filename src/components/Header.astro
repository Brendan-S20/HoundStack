---
import { SITE, NAV } from '../lib/site';
import Icon from './Icon.astro';
import textLogo from '../assets/HoundStackText-trim.svg';

const links = [
  { href: '/pricing', label: 'Pricing' },
  { href: '/switch', label: 'Switch' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const path = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <a href="/" class="logo-link" aria-label="HoundStack home">
      <img src={textLogo.src} alt="HoundStack" width="170" height="36" />
    </a>

    <nav class="desktop-nav" aria-label="Main">
      <ul>
        <li class="has-mega">
          <a href="/features" aria-current={path.startsWith('/features') ? 'page' : undefined}>
            Features
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6" /></svg>
          </a>
          <div class="mega" role="menu" aria-label="Features">
            <div class="mega-grid">
              {
                NAV.featureGroups.map((g) => (
                  <div class="mega-group">
                    <span class="mega-label">{g.label}</span>
                    {g.items.map((it) => (
                      <a href={it.href} role="menuitem">{it.label}</a>
                    ))}
                  </div>
                ))
              }
            </div>
            <div class="mega-foot">
              <a href="/features">All features →</a>
              <a href="/integrations">Integrations</a>
              <a href="/roadmap">Roadmap</a>
            </div>
          </div>
        </li>
        {
          links.map((l) => (
            <li>
              <a href={l.href} aria-current={path.startsWith(l.href) ? 'page' : undefined}>
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-ctas">
      <a href={SITE.appUrl} class="signin-link" data-app-link>Sign in</a>
      <a href={SITE.signupUrl} class="btn btn-secondary btn-header" data-app-link>Start free</a>
    </div>

    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Open menu"
    >
      <span class="icon-menu"><Icon name="menu" /></span>
      <span class="icon-close"><Icon name="close" /></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile" hidden>
    <ul>
      <li><a href="/features">Features</a></li>
      {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      <li><a href={SITE.appUrl} data-app-link>Sign in</a></li>
    </ul>
    <a href={SITE.signupUrl} class="btn btn-secondary mobile-cta" data-app-link>Start free</a>
  </nav>
</header>

<style>
  /* Fully opaque, always: a translucent backdrop-filter header lags a
     frame behind compositor scrolling and lets page headings bleed
     through the logo for that frame. Only the border and shadow react
     to scroll position. */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .site-header.is-scrolled {
    border-bottom-color: var(--line-soft);
    box-shadow: var(--shadow-sm);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 28px;
    height: var(--header-h);
  }

  .logo-link {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .logo-link img {
    display: block;
    height: 34px;
    width: auto;
  }

  .desktop-nav {
    margin-left: auto;
  }

  .desktop-nav ul {
    display: flex;
    gap: 26px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .desktop-nav a {
    color: var(--navy);
    font-weight: 550;
    font-size: 0.96rem;
  }

  .desktop-nav a:hover,
  .desktop-nav a[aria-current='page'] {
    color: var(--sage-dark);
    text-decoration: none;
  }

  /* Features mega menu: opens on hover and on keyboard focus, closes
     when focus or the pointer leaves. Pure CSS, no JS to fail. */
  .has-mega {
    position: relative;
  }

  .has-mega > a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .mega {
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    width: 620px;
    background: #ffffff;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lift);
    padding: 22px 24px 14px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 140ms ease, transform 140ms ease, visibility 140ms;
    z-index: 60;
  }

  /* Keep the menu reachable: an invisible hover bridge over the gap */
  .mega::before {
    content: '';
    position: absolute;
    top: -16px;
    left: 0;
    right: 0;
    height: 16px;
  }

  .has-mega:hover .mega,
  .has-mega:focus-within .mega {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .mega-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .mega-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 8px;
  }

  .mega-group a {
    display: block;
    padding: 4px 0;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink);
  }

  .mega-group a:hover {
    color: var(--sage-dark);
    text-decoration: none;
  }

  .mega-foot {
    display: flex;
    gap: 20px;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--line-soft);
  }

  .mega-foot a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sage-dark);
  }

  @media (prefers-reduced-motion: reduce) {
    .mega {
      transition: none;
    }
  }

  .header-ctas {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-shrink: 0;
  }

  .signin-link {
    color: var(--navy);
    font-weight: 550;
    font-size: 0.96rem;
  }

  .btn-header {
    padding: 9px 18px;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--navy);
    padding: 8px;
    margin-left: auto;
    cursor: pointer;
  }

  .nav-toggle .icon-close { display: none; }
  .nav-toggle[aria-expanded='true'] .icon-menu { display: none; }
  .nav-toggle[aria-expanded='true'] .icon-close { display: block; }

  .mobile-nav {
    display: none;
    border-top: 1px solid var(--line-soft);
    background: #ffffff;
    padding: 12px 24px 24px;
  }

  .mobile-nav ul {
    list-style: none;
    margin: 0 0 16px;
    padding: 0;
  }

  .mobile-nav li a {
    display: block;
    padding: 13px 0;
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--navy);
    border-bottom: 1px solid var(--line-soft);
  }

  .mobile-cta {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 860px) {
    .desktop-nav,
    .header-ctas {
      display: none;
    }

    .nav-toggle {
      display: block;
    }

    .mobile-nav:not([hidden]) {
      display: block;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header')!;
  const toggle = document.getElementById('nav-toggle')!;
  const mobileNav = document.getElementById('mobile-nav')!;

  const onScroll = () => {
    header.classList.toggle('is-scrolled', window.scrollY > 12);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    mobileNav.hidden = open;
    if (!open) header.classList.add('is-scrolled');
  });
</script>
