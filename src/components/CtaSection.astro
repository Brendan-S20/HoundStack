---
import { SITE, TRIAL_DAYS } from '../lib/site';

interface Props {
  heading?: string;
  body?: string;
  /** Pages where the sale starts with a conversation (e.g. HOA programs)
      lead with the contact button instead of the early access list. */
  leadWithContact?: boolean;
}

const {
  heading = 'Be first through the door',
  body = `HoundStack opens to the public soon. Join the early access list for launch news and an early invite, with a ${TRIAL_DAYS} day free trial waiting when the doors open.`,
  leadWithContact = false,
} = Astro.props;
---

<section class="section-navy cta-section">
  <div class="container text-center reveal">
    <h2>{heading}</h2>
    <p class="lede cta-lede">{body}</p>
    <div class="cta-buttons">
      {
        leadWithContact ? (
          <>
            <a href="/contact" class="btn btn-secondary">Talk to us</a>
            <a href={SITE.earlyAccessUrl} class="btn btn-ghost">Coming soon</a>
          </>
        ) : (
          <>
            <a href={SITE.earlyAccessUrl} class="btn btn-secondary">Coming soon</a>
            <a href="/contact" class="btn btn-ghost">Talk to us</a>
          </>
        )
      }
      <a href="/pricing" class="btn btn-ghost">See pricing</a>
    </div>
    <p class="cta-note">Early invites go out before launch · Launch news only, no spam · Unsubscribe anytime</p>
  </div>
</section>

<style>
  .cta-lede {
    margin-inline: auto;
    max-width: 40em;
  }

  .cta-buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .cta-note {
    margin: 16px 0 0;
    font-size: 0.88rem;
    color: #b9c9d3;
  }
</style>
