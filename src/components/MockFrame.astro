---
// Chrome around stylized product UI recreations. These are honest
// recreations of real product screens, swapped for screenshots later.
interface Props {
  variant?: 'desktop' | 'phone';
  label: string;
  class?: string;
}

const { variant = 'desktop', label, class: className } = Astro.props;
---

<figure class={`mock mock-${variant} ${className ?? ''}`} role="img" aria-label={label}>
  {
    variant === 'desktop' ? (
      <div class="mock-bar" aria-hidden="true">
        <span /><span /><span />
      </div>
    ) : (
      <div class="mock-status" aria-hidden="true">
        <span class="ms-time">9:41</span>
        <span class="ms-island" />
        <span class="ms-icons">
          <span class="ms-signal"><i /><i /><i /><i /></span>
          <span class="ms-battery" />
        </span>
      </div>
    )
  }
  <div class="mock-body">
    <slot />
  </div>
  {variant === 'phone' && <div class="mock-home" aria-hidden="true" />}
</figure>

<style is:global>
  .mock {
    margin: 0;
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lift);
    overflow: hidden;
    font-size: 0.85rem;
  }

  /* Phone frames keep real handset proportions: a fixed width, a
     minimum screen height, a status bar up top and the home indicator
     at the bottom, so a short screen reads as a phone with breathing
     room instead of a squat card wearing a phone border. */
  .mock-phone {
    width: min(310px, 100%);
    margin-inline: auto;
    border-radius: 36px;
    border-width: 7px;
    border-color: var(--navy);
    display: flex;
    flex-direction: column;
    min-height: 580px;
  }

  .mock-phone .mock-body {
    flex: 1;
  }

  .mock-status {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 18px 4px;
  }

  .ms-time {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--navy);
    font-variant-numeric: tabular-nums;
  }

  .ms-island {
    position: absolute;
    left: 50%;
    top: 9px;
    transform: translateX(-50%);
    width: 76px;
    height: 17px;
    border-radius: 100px;
    background: var(--navy);
  }

  .ms-icons {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .ms-signal {
    display: inline-flex;
    align-items: flex-end;
    gap: 1.5px;
  }

  .ms-signal i {
    width: 2.5px;
    background: var(--navy);
    border-radius: 1px;
  }

  .ms-signal i:nth-child(1) { height: 4px; }
  .ms-signal i:nth-child(2) { height: 6px; }
  .ms-signal i:nth-child(3) { height: 8px; }
  .ms-signal i:nth-child(4) { height: 10px; }

  .ms-battery {
    width: 20px;
    height: 10px;
    border: 1.5px solid var(--navy);
    border-radius: 3px;
    position: relative;
  }

  .ms-battery::after {
    content: '';
    position: absolute;
    inset: 1.5px 30% 1.5px 1.5px;
    background: var(--navy);
    border-radius: 1px;
  }

  .mock-home {
    height: 5px;
    width: 38%;
    margin: 10px auto 8px;
    border-radius: 100px;
    background: var(--line);
  }

  .mock-bar {
    display: flex;
    gap: 6px;
    padding: 11px 14px;
    background: var(--bg-alt);
    border-bottom: 1px solid var(--line-soft);
  }

  .mock-bar span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--line);
  }

  .mock-notch {
    height: 22px;
    background: var(--navy);
    border-radius: 0 0 14px 14px;
    width: 46%;
    margin: 0 auto;
  }

  .mock-body {
    padding: 0;
  }

  /* Shared vocabulary for mock UI content */
  .mk-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--line-soft);
  }

  .mk-title {
    font-weight: 700;
    color: var(--navy);
    font-size: 0.95rem;
  }

  .mk-sub {
    color: var(--ink-faint);
    font-size: 0.78rem;
  }

  .mk-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 11px 18px;
    border-bottom: 1px solid var(--line-soft);
  }

  .mk-row:last-child {
    border-bottom: none;
  }

  .mk-cell {
    display: grid;
    line-height: 1.35;
    min-width: 0;
  }

  .mk-strong {
    font-weight: 600;
    color: var(--navy);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mk-faint {
    color: var(--ink-faint);
    font-size: 0.78rem;
  }

  .mk-num {
    font-variant-numeric: tabular-nums;
    font-weight: 650;
    color: var(--navy);
  }

  .mk-pill {
    padding: 2px 9px;
    border-radius: 100px;
    font-size: 0.72rem;
    font-weight: 650;
    white-space: nowrap;
  }

  /* Semantic status colors, one meaning per hue across every mockup:
     positive  = done well (paid, on pace, matched, signed up)
     warning   = needs attention (unassigned, hazards, pending follow-up)
     neutral   = informational state (due dates, queued, registry IDs)
     negative  = a hard stop (passed, aggressive dog) */
  .mk-pill.positive { background: var(--sage-wash); color: var(--sage-dark); }
  .mk-pill.neutral { background: var(--navy-wash); color: var(--navy); }
  .mk-pill.warning { background: var(--amber-wash); color: var(--amber); }
  .mk-pill.negative { background: var(--red-wash); color: var(--red); }

  .mk-btn {
    display: inline-block;
    padding: 7px 14px;
    border-radius: var(--radius-sm);
    background: var(--navy);
    color: #ffffff;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .mk-btn.sage { background: var(--sage); }

  .mk-bubble {
    max-width: 78%;
    padding: 9px 13px;
    border-radius: 14px;
    margin: 7px 14px;
    font-size: 0.83rem;
    line-height: 1.45;
  }

  .mk-bubble.in {
    background: var(--bg-alt);
    color: var(--ink);
    border-bottom-left-radius: 4px;
    margin-right: auto;
  }

  .mk-bubble.out {
    background: var(--navy);
    color: #ffffff;
    border-bottom-right-radius: 4px;
    margin-left: auto;
  }

  .mk-bars {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 90px;
    padding: 14px 18px 0;
  }

  .mk-bars span {
    flex: 1;
    background: var(--navy-wash);
    border-radius: 4px 4px 0 0;
  }

  .mk-bars span.hot {
    background: var(--sage);
  }
</style>
