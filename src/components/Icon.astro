  close: '<path d="m5.5 5.5 13 13M18.5 5.5l-13 13"/>',
  'arrow-right': '<path d="M4 12h15M13 6l6 6-6 6"/>',
  'chevron-down': '<path d="m6 9.5 6 6 6-6"/>',
