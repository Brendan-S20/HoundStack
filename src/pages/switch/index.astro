---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaSection from '../../components/CtaSection.astro';
import MockFrame from '../../components/MockFrame.astro';
import Icon from '../../components/Icon.astro';
import { COMPETITORS, SWITCH_MARKS } from '../../lib/competitors';

const marks = SWITCH_MARKS;

const shortlines: Record<string, string> = {
  'from-sweep-and-go': 'The trade specific incumbent. The comparison comes down to the AI layer and the interface.',
  'from-jobber': 'Great general field service software that charges per user and has no per dog pricing.',
  'from-housecall-pro': 'Built for plumbers and HVAC. Recurring route work was never its model.',
  'from-time-to-pet': 'Excellent pet sitting software. Waste removal routes ask different questions.',
  'from-gorilladesk': 'Grew up in pest control. The commercial scooping side does not exist there.',
};
---

<BaseLayout
  title="Switch from your pet waste removal software | HoundStack"
  description="Migration guides and named importers for Sweep&Go, Jobber, Housecall Pro, Time To Pet, and GorillaDesk, plus CSV. Every import dry runs first."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Switching</span>
      <h1>Switch from your current software without losing a client record</h1>
      <p class="lede">
        Five competitors have named, dedicated import tools, and a generic CSV importer covers
        everything else. Each one shows a field mapping preview and a dry run summary before a
        single record is written, so the risky part of switching stops being risky.
      </p>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <div class="grid-3 switch-grid">
        {
          COMPETITORS.map((c) => {
            const m = marks[c.slug];
            return (
              <a href={`/switch/${c.slug}`} class="card reveal switch-card">
                <span class="switch-mark" style={`background:${m.bg}; color:${m.fg}; border-color:${m.line}`}>{m.mark}</span>
                <h3>From {c.name} <Icon name="arrow-right" size={16} /></h3>
                <p>{shortlines[c.slug]}</p>
                <span class="switch-tag">Named importer &middot; dry run included</span>
              </a>
            );
          })
        }
        <div class="card reveal switch-card">
          <span class="switch-mark" style="background:var(--sage-wash); color:var(--sage-dark); border-color:#cfdccf">CSV</span>
          <h3>From anywhere else</h3>
          <p>
            The CSV importer takes any export with clients, dogs, schedules, and balances. Same
            mapping preview, same dry run, same safety net.
          </p>
          <span class="switch-tag">Works with any export</span>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container how-split">
      <div class="reveal">
        <h2>Every import works the same way</h2>
        <p class="lede">
          Upload or connect, preview the field mapping, run a dry run that summarizes what would
          change, then confirm. Until that last click, your HoundStack account is untouched.
        </p>
        <ul class="checklist">
          <li>
            <Icon name="check" size={20} />
            <span><strong>Nothing writes early.</strong> The dry run is a full trial pass; the flags it raises are yours to fix or accept first.</span>
          </li>
          <li>
            <Icon name="check" size={20} />
            <span><strong>Everything arrives ready.</strong> Clients, dogs, schedules, and balances land routed and billable, not as a pile of rows.</span>
          </li>
        </ul>
      </div>
      <div class="reveal">
        <MockFrame label="An import dry run summary showing clients, dogs, and schedules ready with a few rows flagged for review">
          <div class="mk-head">
            <div>
              <span class="mk-title">Import &middot; dry run</span>
              <div class="mk-sub">trial pass, nothing written yet</div>
            </div>
            <span class="mk-pill neutral">step 3 of 4</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Clients</span>
              <span class="mk-faint">with properties, gate codes, and notes</span>
            </span>
            <span class="mk-num">214</span>
            <span class="mk-pill positive">ready</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Dogs</span>
              <span class="mk-faint">names, breeds, and per dog pricing</span>
            </span>
            <span class="mk-num">412</span>
            <span class="mk-pill positive">ready</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Flagged for review</span>
              <span class="mk-faint">3 clients missing a zip, 1 duplicate email</span>
            </span>
            <span class="mk-num">4</span>
            <span class="mk-pill warning">review</span>
          </div>
          <div class="mk-row">
            <span class="mk-faint">Confirm to run the real import</span>
            <span class="mk-btn">Confirm import</span>
          </div>
        </MockFrame>
      </div>
    </div>
  </section>

  <CtaSection
    heading="See your own data on the board first"
    body="Start free, import with a dry run, and judge HoundStack with your real clients on real routes."
  />
</BaseLayout>

<style>
  .page-hero {
    padding-top: clamp(40px, 6vw, 72px);
    padding-bottom: clamp(32px, 5vw, 56px);
  }

  .switch-grid {
    align-items: stretch;
  }

  .switch-card {
    display: flex;
    flex-direction: column;
  }

  .switch-card h3 {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .switch-card p {
    flex: 1;
  }

  .switch-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    border: 1px solid;
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
  }

  .switch-tag {
    margin-top: 14px;
    font-size: 0.78rem;
    font-weight: 650;
    color: var(--sage-dark);
  }

  .how-split {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 56px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .how-split {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
