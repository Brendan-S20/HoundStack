---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaSection from '../../components/CtaSection.astro';
import Icon from '../../components/Icon.astro';
import { COMPETITORS } from '../../lib/competitors';

export function getStaticPaths() {
  return COMPETITORS.map((c) => ({ params: { slug: c.slug }, props: { competitor: c } }));
}

const { competitor: c } = Astro.props;

const migrationSteps = [
  {
    title: 'Upload or connect',
    body: `Export your data from ${c.name} and hand it to ${c.importerName}. It knows ${c.name}'s export format, so there is no reshaping files by hand.`,
  },
  {
    title: 'Preview the mapping',
    body: 'Every field is shown mapped to its HoundStack destination before anything happens. Adjust the ones that need it.',
  },
  {
    title: 'Dry run',
    body: 'A full trial pass produces a summary of what would be created, changed, and flagged. Nothing is written yet.',
  },
  {
    title: 'Confirm',
    body: 'Happy with the dry run? Confirm, and the real import runs. Clients, dogs, schedules, and balances arrive ready to route.',
  },
];
---

<BaseLayout title={c.metaTitle} description={c.metaDescription}>
  <section class="page-hero">
    <div class="container">
      <Breadcrumbs
        crumbs={[
          { label: 'Home', href: '/' },
          { label: 'Switch', href: '/switch' },
          { label: c.name, href: `/switch/${c.slug}` },
        ]}
      />
      <span class="eyebrow">Switching from {c.name}</span>
      <h1>{c.h1}</h1>
      <p class="lede">{c.intro}</p>
    </div>
  </section>

  <section class="section-alt">
    <div class="container compare-grid">
      <div class="card reveal">
        <h2 class="compare-h">Where {c.name} is genuinely good</h2>
        <p>{c.strengths}</p>
      </div>
      <div class="card reveal">
        <h2 class="compare-h">Where it stops for this trade</h2>
        <p>{c.gaps}</p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2 class="reveal">The parts of HoundStack that close the gap</h2>
      <div class="grid-2 gap-links">
        {
          c.weakSpotLinks.map((l) => (
            <a href={l.href} class="card reveal">
              <h3>{l.label} <Icon name="arrow-right" size={18} /></h3>
              <p>See {l.why}.</p>
            </a>
          ))
        }
      </div>
      <p class="reveal pricing-line">
        And the pricing model is different at the root: <a href="/pricing">active clients only,
        never per seat</a>, with unlimited staff on every plan.
      </p>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <h2 class="reveal">What the migration actually looks like</h2>
      <p class="lede reveal">
        {c.name} has a named, dedicated import tool in HoundStack. Four steps, and nothing is
        written to your account until you have seen a dry run summary.
      </p>
      <ol class="steps">
        {
          migrationSteps.map((s, i) => (
            <li class="reveal">
              <span class="step-num">{i + 1}</span>
              <div>
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <CtaSection
    heading="Bring your book over without a lost weekend"
    body={`Start free, run ${c.importerName} with a dry run, and see your own clients on the dispatch board before you commit to anything.`}
  />
</BaseLayout>

<style>
  .page-hero {
    padding-top: clamp(40px, 6vw, 72px);
    padding-bottom: clamp(32px, 5vw, 56px);
  }

  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  @media (max-width: 800px) {
    .compare-grid {
      grid-template-columns: 1fr;
    }
  }

  .compare-h {
    font-size: 1.3rem;
  }

  .gap-links {
    margin-top: 28px;
  }

  .gap-links h3 {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pricing-line {
    margin-top: 28px;
    font-size: 1.05rem;
    color: var(--ink-muted);
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
    display: grid;
    gap: 22px;
    max-width: 720px;
  }

  .steps li {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 18px;
    align-items: start;
  }

  .step-num {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--navy);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }

  .steps h3 {
    margin-bottom: 4px;
  }

  .steps p {
    color: var(--ink-muted);
    margin: 0;
  }
</style>
