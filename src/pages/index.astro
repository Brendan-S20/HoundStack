---
import BaseLayout from '../layouts/BaseLayout.astro';
import RouteWidget from '../components/RouteWidget.astro';
import CtaSection from '../components/CtaSection.astro';
import MockFrame from '../components/MockFrame.astro';
import FaqBlock from '../components/FaqBlock.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { SITE, TRIAL_DAYS, PRICING_FAQS } from '../lib/site';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const postDate = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'HoundStack',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: SITE.url,
  description:
    'Pet waste removal software: scheduling, route optimization, dispatch, offline mobile app, billing, commercial and HOA tools, and AI tools in one product.',
  offers: {
    '@type': 'Offer',
    price: '79',
    priceCurrency: 'USD',
    description:
      'Launch plan at $79 per month with 3 active employees included, after a 60 day free trial with no credit card required.',
  },
};

const featureCards = [
  {
    href: '/features/scheduling-and-routes',
    icon: 'route',
    title: 'Scheduling and routes',
    body: 'Recurring visits, zone pricing by postal prefix, a drag and drop dispatch board, and one click route optimization with real drive time math.',
  },
  {
    href: '/features/field-app',
    icon: 'phone',
    title: 'The field app',
    body: 'A My Day view built for the truck. Full offline completion, required before and after photos, and safety hazards shown before the gate opens.',
  },
  {
    href: '/features/billing',
    icon: 'card',
    title: 'Billing and payments',
    body: 'Prepaid credits or postpaid invoices, Stripe with your own key and no markup, and billing rules that know why a visit was skipped.',
  },
  {
    href: '/features/commercial-and-hoa',
    icon: 'building',
    title: 'Commercial and HOA',
    body: 'Per unit billing for communities, waste station service routes, and DNA compliance with chain of custody tracking.',
  },
  {
    href: '/features/neighbor-referrals',
    icon: 'pin',
    title: 'Neighbors and referrals',
    body: 'Two way SMS, automatic review prompts, referral credits for both sides, and a canvassing map that works your clients’ streets.',
  },
  {
    href: '/features/ai-tools',
    icon: 'spark',
    title: 'AI tools',
    body: 'An in house AI receptionist that books real appointments by text, churn risk scoring, suggested zone pricing, and a weekly business digest.',
  },
  {
    href: '/features/reporting',
    icon: 'chart',
    title: 'Reporting',
    body: 'Revenue, receivables aging, skip reasons, tech productivity, zone profitability, retention cohorts, and churn drivers.',
  },
];

const alsoInBox = [
  {
    icon: 'import',
    title: 'Named importers',
    body: 'Dedicated import tools for Sweep&Go, Jobber, Housecall Pro, Time To Pet, and GorillaDesk, each with a mapping preview and a dry run.',
    href: '/switch',
  },
  {
    icon: 'network',
    title: 'Franchise rollup',
    body: 'Multi location accounts with automatic royalty billing and a franchisor dashboard across every location.',
    href: '/for/franchise-owners',
  },
  {
    icon: 'users',
    title: 'Scoped roles',
    body: 'Owner, office manager, dispatcher, and tech each get their own experience. Nobody wades through screens their job never touches.',
    href: '/features',
  },
  {
    icon: 'box',
    title: 'Inventory tracking',
    body: 'Bags, deodorizer, and gear tracked per tech, with low stock alerts before someone runs out mid route.',
    href: '/features',
  },
];
---

<BaseLayout
  title="HoundStack: pet waste removal software built for scooper businesses"
  description="Scheduling, route optimization, offline field app, billing, HOA compliance, and AI tools for pet waste removal businesses. 60 day free trial, unlimited customers and zones on every plan."
  schema={[softwareSchema]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1>Run your whole pet waste removal business without paying for who you employ</h1>
        <p class="lede">
          Scheduling, routing, billing, and a field app built for this trade instead of adapted
          to it. Priced by how complex the operation is, never by headcount.
        </p>
        <div class="hero-ctas">
          <a href={SITE.signupUrl} class="btn btn-primary" data-app-link>Start your free trial</a>
          <a href="/pricing" class="btn btn-ghost">See pricing</a>
        </div>
        <p class="hero-note">
          {TRIAL_DAYS} day free trial · No credit card · Unlimited customers, dogs, jobs, routes,
          and zones on every plan
        </p>
      </div>
      <div class="hero-widget">
        <RouteWidget />
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <div class="reveal">
        <span class="eyebrow">Why it exists</span>
        <h2>Built for the route, not adapted to it</h2>
        <p class="lede">
          Generic field service tools make you fight for per dog pricing, skip rules, and gate
          codes. HoundStack starts there. Every screen assumes you are scooping yards, servicing
          waste stations, and getting techs through 20 stops before lunch.
        </p>
      </div>
      <div class="grid-3 feature-grid">
        {
          featureCards.map((c) => (
            <a href={c.href} class="card reveal">
              <span class="card-icon">
                <Icon name={c.icon as any} />
              </span>
              <h3>{c.title}</h3>
              <p>{c.body}</p>
            </a>
          ))
        }
        <a href="/features" class="card reveal card-all">
          <span class="card-icon"><Icon name="arrow-right" /></span>
          <h3>Everything in one place</h3>
          <p>The full feature tour, including inventory, roles, and franchise tools.</p>
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="reveal">
        <span class="eyebrow">The product</span>
        <h2>Have a look around before you sign up</h2>
        <p class="lede">
          The dispatch board, billing, the AI receptionist, and reporting, shown the way they
          look inside the product. Stylized recreations of real screens, not stock mockups.
        </p>
      </div>
      <div class="gallery-grid">
        <MockFrame label="The HoundStack dispatch board showing three techs' routes for the day" class="reveal">
          <div class="mk-head">
            <div>
              <span class="mk-title">Dispatch board</span>
              <div class="mk-sub">Tuesday · Zone 2 north · 3 trucks</div>
            </div>
            <span class="mk-btn sage">Optimize all</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Marcus T.</span>
              <span class="mk-faint">18 stops · done by 2:40</span>
            </span>
            <span class="mk-pill sage">on pace</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Dana R.</span>
              <span class="mk-faint">21 stops · done by 3:10</span>
            </span>
            <span class="mk-pill sage">on pace</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Priya K.</span>
              <span class="mk-faint">16 stops · Birchwood Court HOA restock</span>
            </span>
            <span class="mk-pill amber">2 unassigned</span>
          </div>
        </MockFrame>

        <MockFrame label="The HoundStack invoice list with paid, due, and skip credit statuses" class="reveal">
          <div class="mk-head">
            <div>
              <span class="mk-title">Invoices</span>
              <div class="mk-sub">This month · $8,410 collected</div>
            </div>
            <span class="mk-pill navy">receivables: $1,285</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Kowalski residence</span>
              <span class="mk-faint">2 dogs, weekly</span>
            </span>
            <span class="mk-num">$89</span>
            <span class="mk-pill sage">paid</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Birchwood Court HOA</span>
              <span class="mk-faint">3 stations, per unit</span>
            </span>
            <span class="mk-num">$1,240</span>
            <span class="mk-pill navy">due Apr 1</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Nguyen residence</span>
              <span class="mk-faint">skipped: gate locked</span>
            </span>
            <span class="mk-num">$0</span>
            <span class="mk-pill amber">credit applied</span>
          </div>
        </MockFrame>

        <MockFrame variant="phone" label="An AI receptionist text conversation booking a new weekly client" class="reveal">
          <div class="mk-head">
            <div>
              <span class="mk-title">AI receptionist</span>
              <div class="mk-sub">answering as your business, by text</div>
            </div>
          </div>
          <div class="mk-thread">
            <div class="mk-bubble in">How much for 2 dogs every week? Back yard only.</div>
            <div class="mk-bubble out">
              For 2 dogs weekly it's $22 a visit in your zone. Thursday mornings are open — want
              me to start you April 3?
            </div>
            <div class="mk-bubble in">Yes please</div>
            <div class="mk-bubble out">Booked: Thursdays from April 3. You'll get a text the night before each visit.</div>
          </div>
          <div class="mk-row">
            <span class="mk-faint">Booked by AI · already on the dispatch board</span>
          </div>
        </MockFrame>

        <MockFrame label="A HoundStack zone profitability report with monthly revenue bars" class="reveal">
          <div class="mk-head">
            <div>
              <span class="mk-title">Zone profitability</span>
              <div class="mk-sub">Last 6 months</div>
            </div>
            <span class="mk-pill sage">margin up 4%</span>
          </div>
          <div class="mk-bars" aria-hidden="true">
            <span style="height: 42%"></span>
            <span style="height: 55%"></span>
            <span style="height: 49%"></span>
            <span style="height: 66%"></span>
            <span style="height: 74%"></span>
            <span class="hot" style="height: 88%"></span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Zone 2 north</span>
              <span class="mk-faint">densest route, 4 min between stops</span>
            </span>
            <span class="mk-num">61% margin</span>
          </div>
          <div class="mk-row">
            <span class="mk-cell">
              <span class="mk-strong">Zone 5 east</span>
              <span class="mk-faint">flagged: drive time creeping up</span>
            </span>
            <span class="mk-num">38% margin</span>
          </div>
        </MockFrame>
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="container pricing-teaser reveal">
      <div>
        <span class="eyebrow">Pricing</span>
        <h2>Priced by how complex the operation is, not how big</h2>
        <p class="lede">
          Customers, dogs, jobs, routes, and zones are unlimited on every plan. Each tier includes
          an employee allowance, your first 3 teammates on Launch, and adding one more is $10 a
          month flat, shown live in the dashboard, never a surprise invoice. What moves you up a
          tier is complexity tooling like advanced analytics and custom permissions, not growth.
        </p>
        <a href="/pricing" class="btn btn-primary">See the full breakdown</a>
      </div>
      <div class="teaser-bands">
        <div class="band"><span class="band-name">Launch</span><span class="band-detail">3 employees included</span><span class="band-price">$79/mo</span></div>
        <div class="band"><span class="band-name">Growth</span><span class="band-detail">10 employees included</span><span class="band-price">$199/mo</span></div>
        <div class="band"><span class="band-name">Scale</span><span class="band-detail">30 employees included</span><span class="band-price">$449/mo</span></div>
        <div class="band"><span class="band-name">Enterprise</span><span class="band-detail">franchise and multi-brand parents</span><span class="band-price">by contract</span></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="reveal">
        <span class="eyebrow">Also in the box</span>
        <h2>The unglamorous stuff is covered too</h2>
      </div>
      <div class="grid-2 alsobox-grid">
        {
          alsoInBox.map((c) => (
            <a href={c.href} class="card reveal">
              <span class="card-icon">
                <Icon name={c.icon as any} />
              </span>
              <h3>{c.title}</h3>
              <p>{c.body}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="container reveal">
      <span class="eyebrow">Switching</span>
      <h2>Already running on something else?</h2>
      <p class="lede">
        There are named import tools for Sweep&amp;Go, Jobber, Housecall Pro, Time To Pet, and
        GorillaDesk, plus a CSV importer for anything else. Every import shows you a field mapping
        preview and a dry run summary before a single record is written.
      </p>
      <a href="/switch" class="btn btn-ghost">See the migration guides <Icon name="arrow-right" size={18} /></a>
    </div>
  </section>

  <section>
    <div class="container faq-home reveal">
      <span class="eyebrow">Straight answers</span>
      <FaqBlock faqs={PRICING_FAQS.slice(0, 3)} heading="The questions everyone asks first" />
      <p class="faq-more">
        More on contracts, allowances, and downgrades in the <a href="/pricing">full pricing FAQ</a>.
      </p>
    </div>
  </section>

  <section class="section-alt">
    <div class="container founder-strip reveal">
      <div>
        <span class="eyebrow">Who's behind this</span>
        <h2>Built by someone who watched this trade closely</h2>
        <p class="lede">
          "HoundStack started with looking hard at how scooper businesses actually run their day,
          and at software that charges you more for every person you hire. This trade deserved a
          tool built from the route up, so I'm building it."
        </p>
        <p class="founder-sig">
          — Brendan Schmidt, founder · <a href="/about">read the whole story</a>
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="reveal">
        <span class="eyebrow">From the blog</span>
        <h2>Writing for operators, not for algorithms</h2>
      </div>
      <div class="grid-3 blog-grid">
        {
          posts.map((post) => (
            <a href={`/blog/${post.id}`} class="card reveal">
              <time datetime={post.data.pubDate.toISOString()} class="post-date">
                {postDate.format(post.data.pubDate)}
              </time>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection
    heading="Put it on one truck this week"
    body="Start a 60 day free trial, no credit card, no usage triggers. Or book a demo and we will walk your actual route setup through it."
  />
</BaseLayout>

<style>
  .hero {
    padding-top: clamp(40px, 7vw, 88px);
    padding-bottom: clamp(48px, 7vw, 88px);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .hero-badge {
    margin-bottom: 20px;
    font-size: 0.82rem;
  }

  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .hero-note {
    margin-top: 14px;
    font-size: 0.9rem;
    color: var(--ink-faint);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .feature-grid {
    margin-top: 40px;
  }

  .card-all {
    background: var(--navy);
    border-color: var(--navy);
  }

  .card-all h3 {
    color: #ffffff;
  }

  .card-all p {
    color: #b9c9d3;
  }

  .card-all .card-icon {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
  }

  .pricing-teaser {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .teaser-bands {
    display: grid;
    gap: 8px;
  }

  .band {
    display: grid;
    grid-template-columns: 110px 1fr auto;
    gap: 12px;
    align-items: baseline;
    padding: 13px 18px;
    background: #ffffff;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
  }

  .band-name {
    font-weight: 700;
    color: var(--navy);
  }

  .band-detail {
    color: var(--ink-faint);
    font-size: 0.88rem;
  }

  .band-price {
    font-weight: 700;
    color: var(--sage-dark);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 900px) {
    .pricing-teaser {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .alsobox-grid {
    margin-top: 36px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-top: 40px;
    align-items: start;
  }

  @media (max-width: 860px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  .mk-thread {
    padding: 8px 0;
  }

  .faq-more {
    margin-top: 20px;
    color: var(--ink-muted);
  }

  .founder-strip .lede {
    max-width: 42em;
  }

  .founder-sig {
    font-weight: 600;
    color: var(--navy);
  }

  .blog-grid {
    margin-top: 36px;
  }

  .post-date {
    display: block;
    font-size: 0.85rem;
    color: var(--ink-faint);
    margin-bottom: 8px;
  }
</style>
