---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingEstimator from '../components/PricingEstimator.astro';
import FaqBlock from '../components/FaqBlock.astro';
import CtaSection from '../components/CtaSection.astro';
import Icon from '../components/Icon.astro';
import {
  PLANS,
  SITE,
  TRIAL_DAYS,
  OVERAGE_RATE,
  ANNUAL_DISCOUNT,
  PRICING_FAQS,
  TIER_FEATURE_GROUPS,
} from '../lib/site';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'HoundStack',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: SITE.url,
  offers: PLANS.filter((p) => p.price !== null).map((p) => ({
    '@type': 'Offer',
    name: `HoundStack ${p.name}`,
    price: String(p.price),
    priceCurrency: 'USD',
    description: `$${p.price} per month with ${p.includedEmployees} active employees included. Additional active employees are $${OVERAGE_RATE} per month each. Unlimited customers, dogs, jobs, routes, and zones.`,
  })),
};

// Add-on detail blurbs. Availability itself lives in TIER_FEATURE_GROUPS
// (rendered inside every tier card); this section only explains what
// each add-on does.
const addons = [
  {
    icon: 'spark',
    name: 'AI Receptionist',
    body: 'Answers client texts about pricing and availability and books straight into the calendar. Texts today; voice calls are on the roadmap and will be labeled when live.',
    availability: 'Add-on, every plan',
  },
  {
    icon: 'chart',
    name: 'AI Business Advisor',
    body: 'The weekly digest: revenue, completed visits, at risk clients, and one recommended action, computed from your real numbers and delivered every week.',
    availability: 'Add-on, every plan',
  },
  {
    icon: 'users',
    name: 'Referral Programs',
    body: 'Referral codes with credit applied automatically to both the referrer and the new client. Built for the two doors down growth this trade actually runs on.',
    availability: 'Add-on, every plan',
  },
  {
    icon: 'network',
    name: 'Franchise Management and Regional Dashboards',
    body: 'Parent and child organizations, automatic royalty billing, and rollup reporting across every location in the network.',
    availability: 'Included with Enterprise',
  },
];

const faqs = PRICING_FAQS;

const discountPct = Math.round(ANNUAL_DISCOUNT * 100);

/** Per-month price under yearly billing, formatted without trailing .00 */
const yearlyMonthly = (price: number) => {
  const v = price * (1 - ANNUAL_DISCOUNT);
  return Number.isInteger(v) ? String(v) : v.toFixed(2);
};
---

<BaseLayout
  title="Pooper scooper software pricing: Launch $79, Growth $199, Scale $449 | HoundStack"
  description="HoundStack pricing by operational complexity, not headcount: Launch $79, Growth $199, Scale $449, Enterprise by contract. First teammates included, $10 flat after, 60 day free trial."
  schema={[softwareSchema]}
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Pricing</span>
      <h1>Pooper scooper software pricing built around complexity, not headcount</h1>
      <p class="lede">
        Your plan is set by how complex the operation is, not how many customers you have earned
        or how many people it takes to run it. Every tier includes an employee allowance, and one
        more teammate is ${OVERAGE_RATE} a month flat. Customers, dogs, jobs, routes, zones, and
        cities are unlimited on every plan.
      </p>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <div class="tiers-head reveal">
        <div>
          <h2>Four tiers, one ladder</h2>
          <p class="lede">
            Every plan runs the full core ERP with nothing held back. What changes as you move up
            is the tooling a more complex operation actually needs.
          </p>
        </div>
        <div class="billing-toggle" role="group" aria-label="Billing period" id="billing-toggle">
          <button type="button" class="bt-opt is-active" data-billing-opt="monthly" aria-pressed="true">
            Monthly
          </button>
          <button type="button" class="bt-opt" data-billing-opt="yearly" aria-pressed="false">
            Yearly &middot; save {discountPct}%
          </button>
        </div>
      </div>
      <div class="plan-grid" id="plan-grid">
        {
          PLANS.map((p, i) => (
            <div class={`card plan-card reveal ${p.popular ? 'plan-popular' : ''}`}>
              {p.popular && <span class="badge badge-sage popular-badge">Most popular</span>}
              <h3>{p.name}</h3>
              <p class="plan-price">
                {p.price !== null ? (
                  <>
                    <span class="price-monthly">
                      <span class="plan-amount">${p.price}</span>
                      <span class="plan-suffix">/mo</span>
                    </span>
                    <span class="price-yearly">
                      <span class="plan-amount">${yearlyMonthly(p.price)}</span>
                      <span class="plan-suffix">/mo billed yearly</span>
                    </span>
                  </>
                ) : (
                  <span class="plan-amount plan-custom">By contract</span>
                )}
              </p>
              <p class="plan-emp">
                {p.includedEmployees !== null
                  ? `${p.includedEmployees} active employees included`
                  : 'Custom employee allowance'}
              </p>
              <p class="plan-blurb">{p.audience}</p>
              {p.price !== null ? (
                <a
                  href={SITE.signupUrl}
                  class={`btn plan-cta ${p.popular ? 'btn-secondary' : 'btn-ghost'}`}
                  data-app-link
                >
                  Choose {p.name}
                </a>
              ) : (
                <a href="/contact" class="btn btn-ghost plan-cta">
                  Talk to sales
                </a>
              )}
              <ul class="plan-ladder">
                {p.ladder.map((item) => (
                  <li>
                    <Icon name="check" size={16} /> {item}
                  </li>
                ))}
              </ul>
              <details class="plan-features">
                <summary>See all {p.name} features</summary>
                {TIER_FEATURE_GROUPS.map((g) => {
                  const feats = g.features.filter((f) => f.tiers[i] !== false);
                  return feats.length ? (
                    <div class="pf-group">
                      <h4>{g.category}</h4>
                      <ul>
                        {feats.map((f) => (
                          <li>
                            <Icon name="check" size={14} />
                            <span>
                              {f.label}
                              {typeof f.tiers[i] === 'string' && <em> &middot; {f.tiers[i]}</em>}
                            </span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ) : null;
                })}
              </details>
            </div>
          ))
        }
      </div>
      <p class="plan-note reveal">
        Additional active employees are ${OVERAGE_RATE} per month flat on Launch, Growth, and
        Scale. Operating across three cities costs the same as operating across one street: zones
        and territories are structure, not a meter.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="reveal est-head">
        <h2>Put your own numbers in</h2>
        <p class="lede">
          Pick the shape of your operation and drag the team size; the totals update live across
          every published tier.
        </p>
      </div>
      <div class="reveal">
        <PricingEstimator />
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <h2 class="reveal">What the add-ons actually do</h2>
      <p class="lede reveal">
        Each tier card above lists which add-ons it can install; this is what they are. Everything
        listed here is live in the product today; more are in development and will appear when
        they ship.
      </p>
      <div class="grid-2 addon-grid">
        {
          addons.map((a) => (
            <div class="card reveal">
              <span class="card-icon">
                <Icon name={a.icon as any} />
              </span>
              <h3>{a.name}</h3>
              <p>{a.body}</p>
              <span class="badge badge-sage addon-badge">{a.availability}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="container reveal enterprise-block">
      <span class="eyebrow">Enterprise</span>
      <h2>For franchise and multi-brand parents</h2>
      <p class="lede">
        Enterprise is not a size, it is a structure: a parent organization overseeing separately
        run child businesses that roll up to it. It includes franchise management, automatic
        royalty billing, regional dashboards, a custom employee allowance, and a dedicated
        account manager, priced by contract against your locations, allowance, and term.
      </p>
      <a href="/contact" class="btn btn-primary">Talk to sales about Enterprise</a>
    </div>
  </section>

  <section class="section-alt">
    <div class="container reveal">
      <FaqBlock faqs={faqs} heading="Pricing questions, answered straight" />
    </div>
  </section>

  <CtaSection
    heading="Run the trial on your real routes"
    body={`Every account starts with ${TRIAL_DAYS} days of Launch free, no credit card, purely time based. Import your book with a dry run and judge it on your own operation.`}
  />
</BaseLayout>

<style>
  .page-hero {
    padding-top: clamp(40px, 6vw, 72px);
    padding-bottom: clamp(32px, 5vw, 56px);
  }

  .tiers-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    flex-wrap: wrap;
  }

  .billing-toggle {
    display: inline-flex;
    border: 1.5px solid var(--line);
    border-radius: 100px;
    padding: 3px;
    background: #ffffff;
    flex-shrink: 0;
  }

  .bt-opt {
    border: none;
    background: transparent;
    padding: 8px 18px;
    border-radius: 100px;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 650;
    color: var(--ink-muted);
    cursor: pointer;
    white-space: nowrap;
  }

  .bt-opt.is-active {
    background: var(--navy);
    color: #ffffff;
  }

  .plan-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-top: 32px;
    align-items: start;
  }

  @media (max-width: 1020px) {
    .plan-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 620px) {
    .plan-grid {
      grid-template-columns: 1fr;
    }
  }

  .plan-card {
    padding: 24px;
    position: relative;
  }

  .plan-popular {
    border-color: var(--sage);
    border-width: 2px;
    box-shadow: var(--shadow-lift);
  }

  /* margin, not transform, so the .reveal transition cannot cancel the lift */
  @media (min-width: 1021px) {
    .plan-popular {
      margin-top: -8px;
    }
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 20px;
    background: var(--sage);
    color: #ffffff;
  }

  .plan-card h3 {
    margin-bottom: 6px;
  }

  .plan-price {
    margin-bottom: 4px;
  }

  /* The billing toggle swaps which price rendering is shown */
  .price-yearly {
    display: none;
  }

  .plan-grid.billing-yearly .price-yearly {
    display: inline;
  }

  .plan-grid.billing-yearly .price-monthly {
    display: none;
  }

  .plan-amount {
    font-size: 1.9rem;
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -0.02em;
  }

  .plan-custom {
    font-size: 1.35rem;
  }

  .plan-suffix {
    color: var(--ink-faint);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .plan-emp {
    font-weight: 650;
    color: var(--sage-dark);
    font-size: 0.9rem;
    margin-bottom: 10px;
  }

  .plan-blurb {
    min-height: 4em;
    font-size: 0.92rem;
  }

  .plan-cta {
    width: 100%;
    justify-content: center;
    margin-bottom: 4px;
  }

  .plan-ladder {
    list-style: none;
    padding: 0;
    margin: 14px 0 0;
    display: grid;
    gap: 9px;
    font-size: 0.88rem;
    color: var(--ink-muted);
  }

  .plan-ladder li {
    display: grid;
    grid-template-columns: 16px 1fr;
    gap: 8px;
    align-items: start;
  }

  .plan-ladder svg {
    color: var(--sage-dark);
    margin-top: 3px;
  }

  /* Complete per-tier feature list, collapsed by default */
  .plan-features {
    margin-top: 16px;
    border-top: 1px solid var(--line-soft);
    padding-top: 12px;
  }

  .plan-features summary {
    cursor: pointer;
    font-size: 0.88rem;
    font-weight: 650;
    color: var(--sage-dark);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .plan-features summary::-webkit-details-marker {
    display: none;
  }

  .plan-features summary::after {
    content: '';
    width: 7px;
    height: 7px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    transition: transform 160ms ease;
    margin-top: -3px;
  }

  .plan-features[open] summary::after {
    transform: rotate(-135deg);
    margin-top: 3px;
  }

  .pf-group {
    margin-top: 14px;
  }

  .pf-group h4 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 8px;
  }

  .pf-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 7px;
    font-size: 0.84rem;
    color: var(--ink-muted);
  }

  .pf-group li {
    display: grid;
    grid-template-columns: 14px 1fr;
    gap: 8px;
    align-items: start;
  }

  .pf-group li svg {
    color: var(--sage-dark);
    margin-top: 3px;
  }

  .pf-group em {
    font-style: normal;
    color: var(--ink-faint);
  }

  .plan-note {
    margin-top: 28px;
    color: var(--ink-muted);
    max-width: 52em;
  }

  .est-head {
    margin-bottom: 28px;
  }

  .addon-grid {
    margin-top: 32px;
  }

  .addon-badge {
    margin-top: 14px;
  }

  .enterprise-block .lede {
    max-width: 52em;
  }
</style>

<script>
  // Monthly/yearly billing toggle: swaps the rendered price on each
  // tier card. Both prices are rendered server-side; this only flips
  // which one is visible.
  const grid = document.getElementById('plan-grid')!;
  const opts = document.querySelectorAll<HTMLButtonElement>('[data-billing-opt]');
  opts.forEach((btn) =>
    btn.addEventListener('click', () => {
      grid.classList.toggle('billing-yearly', btn.dataset.billingOpt === 'yearly');
      opts.forEach((b) => {
        const active = b === btn;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', String(active));
      });
    })
  );
</script>
