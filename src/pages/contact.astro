---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import { SITE } from '../lib/site';
---

<BaseLayout
  title="Contact HoundStack: talk to a person"
  description="Talk to a person before you commit. Bring routes, pricing, migration, or Enterprise questions and get an answer within one business day."
>
  <section class="page-hero">
    <div class="container contact-grid">
      <div>
        <span class="eyebrow">Contact</span>
        <h1>Talk to a person before you commit</h1>
        <p class="lede">
          This form is for questions the site does not answer, and it is the starting point for
          Enterprise: franchise and multi-brand parents overseeing separate businesses. Bring
          your migration, commercial account, or rollup questions and you will get a real answer
          by email, from the person building the product, within one business day.
        </p>
        <p class="muted">
          Just want in as soon as it opens? Skip the conversation and <a href="/early-access">join the early access list</a> instead.
        </p>
      </div>
      <div class="reveal">
        <LeadForm
          endpoint={SITE.contactFormEndpoint}
          eventName="Contact Submitted"
          messageLabel="What should we cover?"
          messagePlaceholder="Current software, client count, what is not working, anything else"
          submitLabel="Send message"
          confirmHeading="Got it, talk soon"
          confirmBody="Your message is in. Expect an email within one business day."
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: clamp(40px, 6vw, 72px);
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
