---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../lib/site';
---

<BaseLayout
  title="Start a free HoundStack account"
  description="Start now, no call needed. Request a free HoundStack account: free while you have 3 or fewer active clients, no credit card, unlimited staff on every plan."
>
  <section class="page-hero">
    <div class="container contact-grid">
      <div>
        <span class="eyebrow">Start free</span>
        <h1>Start a free account, no call needed</h1>
        <p class="lede">
          This is the self serve path: fill this in and you will get access to your account by
          email. Free while you have 3 or fewer active clients, no credit card, and every feature
          is included from day one.
        </p>
        <ul class="checklist start-list">
          <li>
            <Icon name="check" size={20} />
            <span><strong>Nothing to buy today.</strong> The free tier is real and stays free at 3 or fewer active clients.</span>
          </li>
          <li>
            <Icon name="check" size={20} />
            <span><strong>Unlimited staff, even on Free.</strong> Bring your techs in on day one.</span>
          </li>
          <li>
            <Icon name="check" size={20} />
            <span><strong>Your data stays yours.</strong> One click export whenever you want it.</span>
          </li>
        </ul>
        <p class="muted">
          Want a walkthrough with a human before deciding? That is what the
          <a href="/contact">demo form</a> is for.
        </p>
      </div>
      <div class="reveal">
        <LeadForm
          endpoint={SITE.requestAccessFormEndpoint}
          eventName="Request Access Submitted"
          messageLabel="Anything we should know? (optional)"
          messagePlaceholder="Current software, rough client count, when you want to start"
          submitLabel="Request free access"
          confirmHeading="You are on the way"
          confirmBody="Request received. Watch your inbox for your account access email."
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: clamp(40px, 6vw, 72px);
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .start-list {
    margin-bottom: 20px;
  }
</style>
