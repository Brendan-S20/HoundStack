---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import Icon from '../components/Icon.astro';
import { SITE, TRIAL_DAYS } from '../lib/site';
---

<BaseLayout
  title="Start a 60 day free trial of HoundStack"
  description="Start now, no call needed. Request a HoundStack account and get 60 days of the Launch plan free: no credit card, purely time based, with nothing deleted if you pause."
>
  <section class="page-hero">
    <div class="container contact-grid">
      <div>
        <span class="eyebrow">Start free</span>
        <h1>Start a {TRIAL_DAYS} day free trial, no call needed</h1>
        <p class="lede">
          This is the self serve path: fill this in and you will get access to your account by
          email. The trial is {TRIAL_DAYS} days of the full Launch plan, no credit card, and it is
          purely a clock. Nothing you do inside it, not signing clients, not hiring, not running
          routes, triggers a charge.
        </p>
        <ul class="checklist start-list">
          <li>
            <Icon name="check" size={20} />
            <span><strong>The whole product, not a demo.</strong> The full core ERP from day one: scheduling, routing, billing, the field app, all of it.</span>
          </li>
          <li>
            <Icon name="check" size={20} />
            <span><strong>No usage triggers.</strong> The trial ends when the clock does, not when your business grows.</span>
          </li>
          <li>
            <Icon name="check" size={20} />
            <span><strong>Nothing deleted after.</strong> Convert to Launch at $79 a month, or the account pauses with your data preserved and exportable.</span>
          </li>
        </ul>
        <p class="muted">
          Want a walkthrough with a human before deciding? That is what the
          <a href="/contact">demo form</a> is for.
        </p>
      </div>
      <div class="reveal">
        <LeadForm
          endpoint={SITE.requestAccessFormEndpoint}
          eventName="Request Access Submitted"
          messageLabel="Anything we should know? (optional)"
          messagePlaceholder="Current software, team size, when you want to start"
          submitLabel="Start my free trial"
          confirmHeading="You are on the way"
          confirmBody="Request received. Watch your inbox for your account access email and your 60 day trial."
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: clamp(40px, 6vw, 72px);
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .start-list {
    margin-bottom: 20px;
  }
</style>
