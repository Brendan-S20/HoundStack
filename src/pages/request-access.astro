---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import Icon from '../components/Icon.astro';
import { SITE, TRIAL_DAYS } from '../lib/site';
---

<BaseLayout
  title="Start a 60 day free trial of HoundStack"
  description="Create your account now and get 60 days of the Launch plan free: no credit card, purely time based, with nothing deleted if you pause. Or have us set it up and run your import for you."
>
  <section class="page-hero">
    <div class="container contact-grid">
      <div>
        <span class="eyebrow">Start free</span>
        <h1>Start a {TRIAL_DAYS} day free trial</h1>
        <p class="lede">
          The fastest path is self serve: <a href={SITE.signupUrl} data-app-link>create your account now</a> and you are inside
          the product in a couple of minutes. The trial is {TRIAL_DAYS} days of the full Launch
          plan, no credit card, and it is purely a clock. Nothing you do inside it, not signing
          clients, not hiring, not running routes, triggers a charge.
        </p>
        <a href={SITE.signupUrl} class="btn btn-primary start-btn" data-app-link>Create my account</a>
        <ul class="checklist start-list">
          <li>
            <Icon name="check" size={20} />
            <span><strong>The whole product, not a demo.</strong> The full core ERP from day one: scheduling, routing, billing, the field app, all of it.</span>
          </li>
          <li>
            <Icon name="check" size={20} />
            <span><strong>No usage triggers.</strong> The trial ends when the clock does, not when your business grows.</span>
          </li>
          <li>
            <Icon name="check" size={20} />
            <span><strong>Nothing deleted after.</strong> Convert to Launch at $79 a month, or the account pauses with your data preserved and exportable.</span>
          </li>
        </ul>
        <p class="muted">
          Want a walkthrough with a human before deciding? That is what the <a href="/contact">demo form</a> is for.
        </p>
      </div>
      <div class="reveal">
        <h2 class="handled-h">Rather have it set up for you?</h2>
        <p class="muted handled-p">
          If you are switching from another platform, we will create the account, run your import
          with a dry run, and hand it over ready to route. Fill this in and expect an email from
          us within one business day.
        </p>
        <LeadForm
          endpoint={SITE.requestAccessFormEndpoint}
          eventName="Request Access Submitted"
          messageLabel="Anything we should know? (optional)"
          messagePlaceholder="Current software, team size, when you want to start"
          submitLabel="Set it up for me"
          confirmHeading="You are on the way"
          confirmBody="Request received. We will email you within one business day to set up your account and your 60 day trial."
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: clamp(40px, 6vw, 72px);
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .start-list {
    margin-bottom: 20px;
  }

  .start-btn {
    margin-bottom: 24px;
  }

  .handled-h {
    font-size: 1.3rem;
  }

  .handled-p {
    margin-bottom: 20px;
  }
</style>
