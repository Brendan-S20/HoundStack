---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CtaSection from '../components/CtaSection.astro';

interface Props {
  metaTitle: string;
  metaDescription: string;
  h1: string;
  eyebrow: string;
  intro: string;
  crumbLabel: string;
  crumbRoot?: { label: string; href: string };
  /** The most relevant switch page for the closing link */
  switchHref: string;
  switchText: string;
  schema?: object[];
}

const {
  metaTitle,
  metaDescription,
  h1,
  eyebrow,
  intro,
  crumbLabel,
  crumbRoot = { label: 'Features', href: '/features' },
  switchHref,
  switchText,
  schema = [],
} = Astro.props;
---

<BaseLayout title={metaTitle} description={metaDescription} schema={schema}>
  <section class="feature-hero">
    <div class="container">
      <Breadcrumbs
        crumbs={[{ label: 'Home', href: '/' }, crumbRoot, { label: crumbLabel, href: Astro.url.pathname }]}
      />
      <span class="eyebrow">{eyebrow}</span>
      <h1>{h1}</h1>
      <p class="lede">{intro}</p>
    </div>
  </section>

  <slot />

  <section class="closing-links">
    <div class="container">
      <div class="closing-grid">
        <a href="/pricing" class="card closing-card reveal">
          <span class="eyebrow">What it costs</span>
          <h3>Plans start at $79 a month</h3>
          <p>
            Your first 3 teammates are included on every plan, and each additional active
            employee is $10 a month flat. See every tier side by side.
          </p>
        </a>
        {
          switchText.length > 0 && (
            <a href={switchHref} class="card closing-card reveal">
              <span class="eyebrow">Coming from somewhere else?</span>
              <h3>{switchText.charAt(0).toUpperCase() + switchText.slice(1)}</h3>
              <p>
                A named importer with a field mapping preview and a dry run, so nothing is
                written to your account until you have approved it.
              </p>
            </a>
          )
        }
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>

<style>
  .feature-hero {
    padding-top: clamp(40px, 6vw, 72px);
    padding-bottom: clamp(32px, 5vw, 56px);
  }

  .closing-links {
    padding-block: 0 64px;
  }

  .closing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (max-width: 720px) {
    .closing-grid {
      grid-template-columns: 1fr;
    }
  }

  .closing-card h3 {
    margin-bottom: 6px;
  }
</style>
