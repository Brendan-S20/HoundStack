---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  /** Extra JSON-LD blocks for this page */
  schema?: object[];
  ogType?: string;
}

const { title, description, schema = [], ogType = 'website' } = Astro.props;

const canonical = new URL(Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, ''), SITE.url).href;
const ogImage = new URL('/og.png', SITE.url).href;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'HoundStack',
  url: SITE.url,
  logo: new URL('/logo-mark.svg', SITE.url).href,
  description:
    'HoundStack is business software built for pet waste removal companies: scheduling, routing, billing, field operations, and growth tools in one app.',
};

const allSchema = [organizationSchema, ...schema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Stamped as early as possible so .reveal only hides content when
      // the reveal script is actually going to run.
      document.documentElement.classList.add('js');
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/logo-mark.svg" />
    <meta name="theme-color" content="#142937" />

    <link
      rel="preload"
      href="/fonts/inter-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="HoundStack" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {allSchema.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    <script
      defer
      data-domain="houndstack.com"
      src="https://plausible.io/js/script.outbound-links.js"
    ></script>
    <script is:inline>
      window.plausible =
        window.plausible ||
        function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
    </script>

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-triggered reveals. Elements with .reveal fade in once.
      // Users with reduced motion and touch viewports get instant
      // visibility via CSS (the hidden state never applies there).
      //
      // Two mechanisms cooperate so content is never caught blank:
      // 1. An IntersectionObserver with a generous *positive* bottom
      //    rootMargin starts the fade while the element is still below
      //    the fold, so it is already at full contrast when it enters.
      // 2. A synchronous scroll/resize fallback instantly reveals (no
      //    fade) anything that made it into the viewport before the
      //    async observer callback ran — fast jumps, anchor links,
      //    scrollbar drags, restored scroll positions.
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const animatable = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const targets = document.querySelectorAll('.reveal');
      if (reduced || !animatable || !('IntersectionObserver' in window)) {
        targets.forEach((el) => el.classList.add('is-visible'));
      } else {
        let pending = new Set<Element>(targets);
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
                pending.delete(entry.target);
              }
            }
          },
          // Fire while the element is still up to 30% of a viewport below
          // the fold: the 360ms fade finishes before a normal scroll
          // brings it fully into view.
          { threshold: 0, rootMargin: '0px 0px 30% 0px' }
        );
        // Anything already in or near the viewport shows instantly with no
        // fade; only content the user scrolls to animates. Avoids the
        // low-contrast first paint on tall sections and on mid-page reloads.
        const instantReveal = (el: Element) => {
          (el as HTMLElement).style.transition = 'none';
          el.classList.add('is-visible');
          io.unobserve(el);
          pending.delete(el);
        };
        const inView = (el: Element) => {
          const r = el.getBoundingClientRect();
          return r.top < window.innerHeight * 0.92 && r.bottom > -40;
        };
        targets.forEach((el) => {
          if (inView(el)) {
            instantReveal(el);
          } else {
            io.observe(el);
          }
        });
        // Safety net: whenever the viewport moves, anything visible but
        // not yet revealed appears immediately. Runs synchronously on the
        // scroll event, so a hidden section can never survive a rendered
        // frame inside the viewport waiting on the observer.
        const catchUp = () => {
          if (!pending.size) return;
          for (const el of [...pending]) {
            if (inView(el)) instantReveal(el);
          }
        };
        window.addEventListener('scroll', catchUp, { passive: true });
        window.addEventListener('resize', catchUp, { passive: true });
        // Browsers restore mid-page scroll positions after this script runs
        // on reload or back-navigation; re-check so restored viewports are
        // never blank.
        window.addEventListener('load', catchUp, { once: true });
        window.addEventListener('pageshow', catchUp);
      }
    </script>
  </body>
</html>
